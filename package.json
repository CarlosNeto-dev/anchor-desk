{
  "name": "anchor-desk",
  "version": "1.0.0",
  "scripts": {
    "watch:scss": "sass --watch --poll src/scss:dist/css",
    "watch:ts": "tsc --watch",
    "watch:html": "cpx \"src/pages/**/*.html\" dist --watch",
    "server": "live-server dist --port=8080",
    "dev": "concurrently \"npm run watch:scss\" \"npm run watch:ts\" \"npm run watch:html\" \"npm run server\"",
    "build": "sass src/scss:dist/css && tsc && cpx src/pages/**/*.html dist"
  },
  
  "devDependencies": {
    "sass": "^1.69.0",
    "typescript": "^5.3.0",
    "live-server": "^1.2.2",
    "cpx": "^1.5.0",
    "concurrently": "^8.2.2"
  }
}
